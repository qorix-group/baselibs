@startuml shared_memory_writer_allocandwrite

title SharedMemoryWriter::AllocAndWrite

start

if (Payload size > max payload size?) then ([Yes])
    :Increment number of drops counter
    due to invalid size;
    stop
else ([No])
endif

:Acquire data;

if (Is data acquired?) then ([Yes])
else ([No])
    :Increment number of drops counter
    due to buffer full;
    stop
endif

:Write header;

:Access memory;

:Write payload;

:Release acquired data;

stop

@enduml
